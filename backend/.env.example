# Backend Environment Variables
# Скопируйте в .env и заполните значения

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=eventhub

# JWT
JWT_SECRET=your-super-secret-key-change-in-production

# App
PORT=3000
NODE_ENV=development

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:5173
